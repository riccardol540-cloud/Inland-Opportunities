# Copy this file to ".env" (which is gitignored) and fill in the token.
# Used by scripts/inland-repo.mjs so the Scout/Producer routines can commit to the
# LIVE GitHub repo via the API (independent of the local clone's state).

GITHUB_TOKEN=github_pat_xxxxxxxx   # fine-grained PAT, Contents: read/write on this repo
GITHUB_REPO=riccardol540-cloud/Inland-Opportunities
GITHUB_BRANCH=main
